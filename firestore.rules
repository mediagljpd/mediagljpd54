rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }

    // Animations: Public read, Admin write
    match /animations/{animationId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(animationId);
    }

    // Bookings: Public read/create, Admin full access
    match /bookings/{bookingId} {
      allow read, create: if true;
      allow update, delete: if isAdmin() && isValidId(bookingId);
    }

    // Admins list: Un utilisateur peut lire son propre document d'admin pour vérifier son statut
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin() && isValidId(adminId);
    }
  }
}
